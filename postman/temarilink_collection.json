					"request": {
						"method": "GET",
						"header": [
							{
								"key": "Authorization",
								"value": "Bearer {{access_token}}",
								"type": "text"
							}
						],
						"url": {
							"raw": "{{base_url}}/api/students/",
							"host": [
								"{{base_url}}"
							],
							"path": [
								"api",
								"students",
								""
							],
							"query": [
								{
									"key": "search",
									"value": "John",
									"disabled": true
								}
							]
						}
					},
					"response": []
				}
			]
		},
